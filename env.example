# =============================================================================
# Backend environment only
# Copy to .env in the repository root for the FastAPI API and worker.
# Frontend public variables live in apps/web/.env.local (see apps/web/env.example).
# =============================================================================

# =============================================================================
# Required provider secrets and URLs
# =============================================================================
OPENROUTER_API_KEY=
GROQ_API_KEY=

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_USER=
SUPABASE_DB_NAME=
SUPABASE_DB_HOST=

POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SUCCESS_URL=
POLAR_PORTAL_RETURN_URL=

# =============================================================================
# Optional provider/runtime config
# =============================================================================
# APP_ENV=local                # default local; set to production in hosted API/worker deployments
# CORS_ALLOW_ORIGINS=https://your-frontend.com
# RATE_LIMIT=60  # base requests per minute, 0 = disabled. Expensive writes are stricter; SSE, webhooks, and meta routes are exempt.
# TRUST_PROXY_HEADERS=false  # enable only behind a trusted ingress/proxy
# POLAR_CHECKOUT_RETURN_URL=
# POLAR_SERVER=sandbox

# =============================================================================
# Optional logging config
# =============================================================================
# Leave this unset locally unless you need JSON logs.
# In production, prefer LOG_FORMAT=json.
#
# LOG_FORMAT=console    # console by default; use json for hosted production logs
